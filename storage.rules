rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasMetadata(key) {
      return resource != null
        && 'metadata' in resource
        && key in resource.metadata;
    }

    function metadataMatchesUser(key) {
      return isSignedIn()
        && hasMetadata(key)
        && resource.metadata[key] == request.auth.uid;
    }

    function canReadAgreementFile(ownerUserId) {
      return isOwner(ownerUserId)
        || metadataMatchesUser('caseOwnerId')
        || metadataMatchesUser('clientUserId')
        || metadataMatchesUser('userId');
    }

    match /case-docs/{userId}/{caseId}/{fileName} {
      allow read, write: if isOwner(userId);
    }

    match /case-docs/{userId}/{fileName} {
      allow read, write: if isOwner(userId);
    }

    match /conversational-intakes/{userId}/{intakeId}/{fileName} {
      allow read, write: if isOwner(userId);
    }

    match /lawyer-client-agreements/{ownerUserId}/{caseId}/{fileName} {
      allow read: if canReadAgreementFile(ownerUserId);
      allow write: if false;
    }

    match /lawyer-client-agreements/{ownerUserId}/{caseId}/{allPaths=**} {
      allow read: if canReadAgreementFile(ownerUserId);
      allow write: if false;
    }

    match /lawyer-client-agreements/{allPaths=**} {
      allow read: if metadataMatchesUser('caseOwnerId')
        || metadataMatchesUser('clientUserId')
        || metadataMatchesUser('userId');
      allow write: if false;
    }
  }
}
